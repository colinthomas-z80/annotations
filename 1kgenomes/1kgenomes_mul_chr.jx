{
    "define" : {
        "num_chr" : 10
    },
    "rules" : [
        {
            "workflow" : "1kgenomes.jx",
            "args" : {"chr_num" : x },
	    "inputs": [ format("ALL.chr%d.250000.vcf", x), 
			format("ALL.chr%d.phase3_shapeit2_mvncall_integrated_v5.20130502.sites.annotation.vcf", x)
			],
	    "outputs": [
			format("chr%d-EAS", x),
			format("chr%d-EAS-freq", x)
			]
        } for x in range(1, num_chr+1)
    ]
}
