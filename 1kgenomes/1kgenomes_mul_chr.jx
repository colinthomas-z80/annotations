{
    "define" : {
        "num_chr" : 3
    },
    "rules" : [
        {
            "workflow" : "1kgenomes.sh.jx",
            "args" : {"chr_num" : x },
            "inputs" : [format("f%d", x)],
            "outputs" : [template("output{x}_{y}") for y in range(5)] 
        } for x in range(1, num_chr)
    ]
}