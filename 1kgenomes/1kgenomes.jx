{
  "define" : {
    "step": 100,
    "num_individuals": 3,
    "chr_num":1,
    "CHR_FILE": format("ALL.chr%d.250000.vcf", chr_num)
  },
  "rules": [
    {
      "command": format("bin/individuals.py %s 1 %d %d 6000", CHR_FILE, x, x+step),
      "outputs": [
        format("chr%dn-%d-%d.tar.gz", chr_num, x, x+step)
      ],
      "inputs": [
        format("ALL.chr%d.250000.vcf", chr_num),
        "bin/individuals.py",
        "columns.txt"
      ]
    } for x in range(1, num_individuals*step, step),
    {
      "command": format("bin/individuals_merge.py 1 %s", join([format("chr1n-%d-%d.tar.gz", x, x + step) for x in range(1, num_individuals*step, step)])),
      "outputs": [
        "chr1n.tar.gz"
      ],
      "inputs": [
        "bin/individuals_merge.py" ] +
        [format("chr1n-%d-%d.tar.gz", x, x + step) for x in range(1, num_individuals*step, step)]
    },
    {
      "command": "bin/sifting.py ALL.chr1.phase3_shapeit2_mvncall_integrated_v5.20130502.sites.annotation.vcf 1",
      "outputs": [
        "sifted.SIFT.chr1.txt"
      ],
      "inputs": [
        "ALL.chr1.phase3_shapeit2_mvncall_integrated_v5.20130502.sites.annotation.vcf",
        "bin/sifting.py"
      ]
    },
    {
      "command": "bin/mutation_overlap.py -c 1 -pop EAS",
      "outputs": [],
      "inputs": [
        "EAS",
        "bin/mutation_overlap.py",
        "chr1n.tar.gz",
        "columns.txt",
        "sifted.SIFT.chr1.txt"
      ]
    },
    {
      "command": "bin/frequency.py -c 1 -pop EAS",
      "outputs": [],
      "inputs": [
        "EAS",
        "bin/frequency.py",
        "chr1n.tar.gz",
        "columns.txt",
        "sifted.SIFT.chr1.txt"
      ]
    }
  ]
}
